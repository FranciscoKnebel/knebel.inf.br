---
const site = 'https://knebel.inf.br';
---
<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="canonical" href={`${site}/pt/`} />
    <link rel="alternate" hreflang="pt-BR" href={`${site}/pt/`} />
    <link rel="alternate" hreflang="en" href={`${site}/en/`} />
    <link rel="alternate" hreflang="x-default" href={`${site}/pt/`} />
    <script is:inline>
      const lang = navigator.language.startsWith('pt') ? 'pt' : 'en';
      window.location.replace('/' + lang + '/');
    </script>
    <noscript>
      <meta http-equiv="refresh" content="0;url=/pt/" />
    </noscript>
  </head>
  <body></body>
</html>
