---
import type { UI } from '../i18n/types';

interface Props {
  t: UI['hero'];
}

const { t } = Astro.props;
---

<section class="hero" id="inicio">
  <div class="aurora-blob aurora-amber"></div>
  <div class="aurora-blob aurora-navy"></div>
  <div class="hero-inner">
    <p class="hero-label">{t.label}</p>
    <h1>
      {t.title}<br />
      <span class="hero-brand">{t.brand}</span>
    </h1>
    <p class="hero-description">{t.description}</p>
    <div class="hero-actions">
      <a href="#servicos" class="btn-primary">{t.ctaPrimary}</a>
      <a href="#contato" class="btn-secondary">{t.ctaSecondary}</a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding: 8rem 1.5rem 5rem;
    min-height: 90vh;
    display: flex;
    align-items: center;
  }

  .aurora-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(60px);
    pointer-events: none;
  }

  .aurora-amber {
    width: 400px;
    height: 400px;
    top: -100px;
    right: -80px;
    background: radial-gradient(circle, rgba(245, 158, 11, 0.18) 0%, transparent 65%);
  }

  .aurora-navy {
    width: 380px;
    height: 380px;
    bottom: -80px;
    left: -60px;
    background: radial-gradient(circle, rgba(14, 165, 233, 0.15) 0%, transparent 65%);
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 1100px;
    margin: 0 auto;
    width: 100%;
  }

  .hero-label {
    font-size: 0.65rem;
    letter-spacing: 0.25rem;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 1.25rem;
  }

  .hero-inner h1 {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 900;
    color: var(--color-text);
    letter-spacing: -0.03em;
    line-height: 1.05;
    margin-bottom: 1.5rem;
  }

  .hero-brand {
    background: var(--gradient-brand);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-description {
    font-size: 1rem;
    color: var(--color-text-secondary);
    max-width: 520px;
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
  }

  .btn-primary {
    background: var(--gradient-brand);
    color: white;
    text-decoration: none;
    padding: 0.75rem 1.75rem;
    border-radius: 20px;
    font-weight: 600;
    font-size: 0.875rem;
    transition: opacity 0.2s;
  }

  .btn-primary:hover {
    opacity: 0.9;
  }

  .btn-secondary {
    color: var(--color-primary);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
  }

  .btn-secondary:hover {
    text-decoration: underline;
  }
</style>
